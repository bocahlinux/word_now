<section class="panel">
  <div class="panel-head">
    <h1>"<%= q.text %>"</h1>
    <div class="muted"><%= q.categories %> - <%= q.author || "Anon" %> - <%= q.created_at %></div>
  </div>

  <div class="muted">Slug: <code><%= q.slug %></code></div>

  <div class="actions">
    <a class="btn" href="/">Kembali</a>
    <a class="btn" href="/random">Random</a>
  </div>
</section>
