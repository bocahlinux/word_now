<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= (typeof title !== "undefined" && title) ? title : "Kata Hari Ini" %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="top">
    <a class="brand" href="/">✍️ Kata Hari Ini</a>
    <nav class="nav">
      <a href="/random">Random</a>
      <a href="/search">Cari</a>
      <% if (isAdmin) { %>
        <a class="pill" href="/admin">Admin</a>
        <form method="post" action="/admin/logout" class="inline">
          <button class="link" type="submit">Logout</button>
        </form>
      <% } else { %>
        <a class="pill" href="/admin/login">Login Admin</a>
      <% } %>
    </nav>
  </header>

  <main class="container">
    <%- body %>
  </main>

  <footer class="foot">
    Dibuat buat nyimpen gombalan & kata-kata. Database: SQLite. Server: Node.js.
  </footer>
</body>
</html>